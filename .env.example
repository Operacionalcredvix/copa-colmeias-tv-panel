# URL publicada do Apps Script para o Radar de Produção.
# Pode colar a URL base do Web App; o painel força rota=radar-tv automaticamente.
# Exemplo:
# APPS_SCRIPT_RADAR_TV_URL=https://script.google.com/macros/s/AKfycb.../exec?rota=radar-tv
APPS_SCRIPT_RADAR_TV_URL=

# Compatibilidade com versões anteriores. Se já existir no Vercel, o painel também aceita esta variável.
APPS_SCRIPT_PRODUCAO_URL=
APPS_SCRIPT_URL=

# Intervalo de atualização do painel em ms. 15000 = 15 segundos.
NEXT_PUBLIC_POLL_MS=15000
